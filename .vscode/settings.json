{
    // Point Pylance to the Backend venv so django-environ resolves cleanly
    "python.defaultInterpreterPath": "${workspaceFolder}/Backend/venv/Scripts/python.exe",

    // Suppress false-positive warnings for Tailwind CSS directives (@tailwind, @apply, @layer)
    "css.lint.unknownAtRules": "ignore",
    "scss.lint.unknownAtRules": "ignore",

    "workbench.colorCustomizations": {
        "activityBar.background": "#411F4F",
        "titleBar.activeBackground": "#5B2B6F",
        "titleBar.activeForeground": "#FDFBFD",
        "titleBar.inactiveBackground": "#411F4F",
        "titleBar.inactiveForeground": "#FDFBFD",
        "statusBar.background": "#411F4F",
        "statusBar.foreground": "#FDFBFD",
        "statusBar.debuggingBackground": "#411F4F",
        "statusBar.debuggingForeground": "#FDFBFD",
        "statusBar.noFolderBackground": "#411F4F",
        "statusBar.noFolderForeground": "#FDFBFD"
    }
}